# Copy this file to deploy/.env and edit the values.
# Do not commit deploy/.env if it contains real passwords.

SERVER_HOST=117.50.216.65
SERVER_USER=root
SSH_PORT=23

# Optional. Leave empty if you have no domain yet, then open http://SERVER_HOST.
DOMAIN=

# Website login. Start with one account; add more later when needed.
WEB_USER=admin
WEB_PASSWORD=change-this-password

# Server paths.
APP_DIR=/opt/streetscope
DATA_DIR=/var/lib/streetscope

# Optional GPU segmentation service. Leave empty if the GPU machine is usually off.
# When you turn the GPU on, paste its URL in the web UI or set this before deployment.
DEFAULT_SEGMENTATION_URL=
